@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

title
  <b>GophKeeper v2025.08.07</b>
  <i>Компонентная диаграмма: Backend Core</i>
end title

' ==== Компоненты ядра ====
Container_Boundary(backend_core, "Backend Core"){
  Component(api_gateway, "gRPC API Gateway", "Go + gRPC", "Принимает запросы от клиентов, маршрутизирует их к сервисам")
  Component(auth_service, "Auth Service", "Go", "Регистрация, аутентификация, управление сессиями, выдача access/refresh токенов")
  Component(data_service, "Data Storage Service", "Go", "Работает с данными и метаданными")
  Component(session_validator, "Session Validator", "Go", "Проверяет валидность access-токена, интегрирован в Auth Service")
}
' ==== Внешние системы ====
ContainerDb(pg_db, "PostgreSQL", "SQL", "Хранит пользователей и метаданные")
ContainerDb(s3_store, "S3 Storage", "S3-compatible", "Хранит зашифрованные данные")

' ==== Взаимодействия ====
Rel(api_gateway, auth_service, "Регистрация, аутентификация, refresh")
Rel(api_gateway, data_service, "CRUD данных")

Rel(auth_service, session_validator, "Проверка токенов")
Rel(auth_service, pg_db, "Чтение/запись пользователей", "SQL")

Rel(data_service, pg_db, "Чтение/запись метаданных", "SQL")
Rel_R(data_service, s3_store, "Чтение/запись зашифрованных данных", "S3 API")

@enduml

