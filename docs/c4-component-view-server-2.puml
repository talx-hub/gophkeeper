@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title
<b>GophKeeper — Core Layers</b>
<i>Transport / Application (Use-case) / Domain / Ports / Adapters</i>
end title

' ==== EXTERNALS ====
ContainerDb(pg_db, "PostgreSQL", "SQL", "Пользователи, метаданные, sealed payloads, refresh-токены")
Container(s3_store, "S3-compatible Storage", "S3 API", "Большие зашифрованные бинарные объекты")
ContainerDb(redis_kv, "Redis (optional)", "KV", "Идемпотентность, временные ключи")

' ==== BACKEND CORE ====
Container_Boundary(core, "GophKeeper Backend Core") {

  ' --- Transport layer (gRPC handlers) ---
  Container_Boundary(transport, "Transport Layer (gRPC)") {
    Component(keeper_grpc, "Keeper gRPC Handler", "Go + gRPC server", "Парсит/валидирует stream, маппит proto⇄domain, дергает use-cases")
  }

  ' --- Application / Use-case layer ---
  Container_Boundary(app, "Application / Use-case Layer") {
    Component(keeper_uc_if, "KeeperUseCase (interface)", "Go interface","Контракт: Add/Get/Delete/List/Sync")
    Component(keeper_service, "KeeperService", "Go","Оркестрация сценариев Add/Get/Delete/List/Sync, транзакции, идемпотентность, проверка CRC/SHA")
  }

  ' --- Domain layer ---
  Container_Boundary(domain, "Domain Layer") {
    Component(domain_model, "Domain Model", "Go types","Metadata, DataType, BytesChunk, StorageRef, инварианты")
    Component(domain_policy, "Policies / Validators", "Go","Проверки: тип→носитель, размер≥0, CRC32C per-chunk, SHA256 whole-object")
  }

  ' --- Ports (interfaces to infrastructure) ---
  Container_Boundary(ports, "Ports (Interfaces to Infra)") {
    Component(port_meta_repo, "MetadataRepository", "Go interface","Create/Get/ListByUser/AttachStorage/Delete")
    Component(port_sealed_repo, "SealedDataRepository", "Go interface","Put/Get/Delete (для AUTH/CARD)")
    Component(port_blob, "BlobStore", "Go interface","OpenUpload/OpenDownload/DeleteObject")
    Component(port_upload, "UploadSession", "Go interface","WritePart/Commit/Abort (S3 multipart)")
    Component(port_uow, "UnitOfWork / TxManager", "Go interface","Do(ctx, fn) — границы транзакции")
    Component(port_idem, "IdempotencyStore (optional)", "Go interface","PutIfAbsent/Get — ключи идемпотентности")
  }

  ' --- Adapters (infrastructure implementations) ---
  Container_Boundary(adapters, "Adapters / Infrastructure") {
    Component(pg_meta_repo, "PgMetadataRepository", "Go + pgx","Реализация MetadataRepository")
    Component(pg_sealed_repo, "PgSealedDataRepository", "Go + pgx","Реализация SealedDataRepository (BYTEA)")
    Component(pg_tx, "PgTxManager", "Go + pgx","Реализация UnitOfWork (BEGIN/COMMIT/ROLLBACK)")
    Component(s3_blob, "MinIO/S3BlobStore", "Go + MinIO SDK","Реализация BlobStore/UploadSession (multipart upload)")
    Component(redis_idem, "RedisIdempotencyStore", "Go + go-redis","Реализация IdempotencyStore")
  }
}

' ==== RELATIONS (inside core) ====
Rel(keeper_grpc, keeper_service, "calls use-cases: Add/Get/Delete/List/Sync", "gRPC → Go")
Rel(keeper_service, keeper_uc_if, "implements", "")
Rel(keeper_service, domain_model, "использует модели/значения", "")
Rel(keeper_service, domain_policy, "валидирует инварианты", "")

' KeeperService -> Ports
Rel(keeper_service, port_meta_repo, "uses", "")
Rel(keeper_service, port_sealed_repo, "uses", "")
Rel(keeper_service, port_blob, "uses", "")
Rel(keeper_service, port_uow, "uses", "")
Rel(keeper_service, port_idem, "uses (optional)", "")

' Ports -> Adapters (implementations)
Rel(pg_meta_repo, port_meta_repo, "implements", "")
Rel(pg_sealed_repo, port_sealed_repo, "implements", "")
Rel(pg_tx, port_uow, "implements", "")
Rel(s3_blob, port_blob, "implements", "")
Rel(redis_idem, port_idem, "implements", "")

' Adapters -> Externals
Rel(pg_meta_repo, pg_db, "SQL", "")
Rel(pg_sealed_repo, pg_db, "SQL", "")
Rel(pg_tx, pg_db, "TX control", "")
Rel(s3_blob, s3_store, "S3 API (Multipart Upload/GET/DELETE)", "")
Rel(redis_idem, redis_kv, "RESP", "")

@enduml
