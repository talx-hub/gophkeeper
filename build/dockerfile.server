FROM golang:1.24-alpine AS builder
WORKDIR /out

COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o server ./cmd/server



FROM alpine:3.20
WORKDIR /app
COPY --from=builder /out/server /app/server

RUN adduser -D -u 10001 app \
    && chown -R app:app /app/server
USER app

EXPOSE 50051
ENTRYPOINT ["/app/server"]
